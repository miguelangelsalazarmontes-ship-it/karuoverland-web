/*
  Access-Control-Allow-Origin: *
  Accept-Ranges: bytes

/assets/video/*
  Content-Type: video/mp4
  Accept-Ranges: bytes
  Cache-Control: public, max-age=31536000

/assets/img/*
  Cache-Control: public, max-age=31536000

/css/*
  Cache-Control: public, max-age=2592000

/js/*
  Cache-Control: public, max-age=2592000

/favicon.ico
  Cache-Control: public, max-age=31536000

/*.html
  Cache-Control: public, max-age=3600
